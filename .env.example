# Copy this file to `.env` and fill in what you need. `.env` is gitignored.

# --- Use Groq (free, fast cloud LLM) instead of local Ollama ---
# Get a free key at https://console.groq.com/keys
# Just setting this key auto-switches the app to Groq.
GROQ_API_KEY=

# Optional: pick a specific Groq model (default: llama-3.3-70b-versatile).
# See https://console.groq.com/docs/models
# MQ_GROQ_MODEL=llama-3.1-8b-instant

# --- Force a provider explicitly (overrides auto-detection) ---
# MQ_PROVIDER=ollama    # or: groq

# --- Other tunables (all optional) ---
# MQ_MAX_RESULTS=10
# MQ_CONCURRENCY=4
# MQ_WHISPER_FALLBACK=1
